# Copy this file to .env. It is ignored by Git.

GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"
GCP_ZONE="your-gke-zone"
GCP_CLUSTER_NAME="your-gke-cluster-name"
GCP_NODE_MACHINE_TYPE="e2-standard-4"
GCP_REQUIRED_VCPUS="8"
GKE_KUBERNETES_VERSION="replace-me"
GCP_BUDGET_DISPLAY_NAME="ai-multicloud-k8s-portfolio"
TF_STATE_BUCKET="your-terraform-state-bucket"

AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
AZURE_LOCATION="centralus"
AZURE_RESOURCE_GROUP="your-azure-resource-group"
AKS_CLUSTER_NAME="your-aks-cluster-name"
AZURE_NODE_VM_SIZE="Standard_D2_v4"
AZURE_REQUIRED_VCPUS="4"
AKS_KUBERNETES_VERSION="replace-me"
AZURE_BUDGET_NAME="ai-multicloud-k8s-portfolio"

GITHUB_REPOSITORY="your-github-owner/AI-Multi-Cloud-K8s"
ADMIN_CIDR="replace-me"

BUDGET_ALERT_EMAIL="replace-me@example.com"
BUDGET_CURRENCY="USD"

DEMO_MAX_BUDGET_USD="100"
# Set a private absolute deadline with a numeric timezone offset.
DEMO_DESTRUCTION_DEADLINE=""

# Export this separately. Never save it in .env.
# ANTHROPIC_API_KEY
